{
    "name": "zhylon/zhylon-auth",
    "description": "Zhylon OAuth2 Provider for Laravel Socialite",
    "license": "MIT",
    "keywords": [
        "zhylon",
        "laravel",
        "oauth",
        "provider",
        "socialite"
    ],
    "authors": [
        {
            "name": "TobyMaxham",
            "email": "git@maxham.de"
        }
    ],
    "support": {
        "issues": "https://github.com/zhylon/zhylon-auth/issues",
        "source": "https://github.com/zhylon/zhylon-auth"
    },
    "require": {
        "php": "^8.3|^8.4|8.5",
        "ext-json": "*",
        "laravel/socialite": "^5.24"
    },
    "require-dev": {
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "Zhylon\\ZhylonAuth\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zhylon\\ZhylonAuth\\Providers\\ZhylonAuthServiceProvider"
            ]
        }
    }
}
